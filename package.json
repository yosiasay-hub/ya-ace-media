{
  "name": "ya-ace-media",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:he": "node scripts/build-locale.mjs he",
    "build:en": "node scripts/build-locale.mjs en",
    "build:all": "npm run build:he && npm run build:en",
    "build:unified": "node scripts/build-unified.mjs",
    "deploy:he": "wrangler deploy",
    "deploy:en": "wrangler deploy --config wrangler.en.jsonc",
    "deploy:all": "npm run deploy:he && npm run deploy:en",
    "deploy:unified": "wrangler pages deploy dist --project-name=ya-ace-media-v3 --branch=main --commit-dirty=true",
    "ship": "npm run build:all && npm run deploy:all",
    "ship:unified": "npm run build:unified && npm run deploy:unified",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "postinstall": "node scripts/strip-next-polyfills.mjs"
  },
  "browserslist": [
    "chrome >= 110",
    "edge >= 110",
    "firefox >= 110",
    "safari >= 16",
    "ios_saf >= 16"
  ],
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@react-email/components": "^0.0.31",
    "@react-email/render": "^1.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "motion": "^12.0.0",
    "next": "^16.0.11",
    "next-intl": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "beasties": "^0.4.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.80.0"
  }
}
